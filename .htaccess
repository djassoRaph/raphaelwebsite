# Root .htaccess

RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# Redirect /index.html to /
RewriteCond %{THE_REQUEST} /index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

# Redirect /blog/index.html to /blog/
RewriteCond %{THE_REQUEST} /blog/index\.html[\s?] [NC]
RewriteRule ^blog/index\.html$ /blog/ [R=301,L]

# Disable directory listing sitewide
Options -Indexes

# Redirect exposed folders with no index
RedirectMatch 301 ^/roots-time/?$ https://raphaelreck.com/roots-time/manifesto.html
RedirectMatch 301 ^/memes/?$ https://raphaelreck.com/fun.html
RedirectMatch 301 ^/scripts/?$ https://raphaelreck.com/
